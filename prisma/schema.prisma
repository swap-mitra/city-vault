generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ORG_ADMIN
  RECORDS_MANAGER
  REVIEWER
  CONTRIBUTOR
  READ_ONLY
  AUDITOR
}

enum RecordStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  ARCHIVED
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  files                  File[]
  records                Record[]
  recordsForReview       Record[]          @relation("CurrentReviewer")
  requestedApprovals     ApprovalRequest[] @relation("RequestedApproval")
  assignedApprovals      ApprovalRequest[] @relation("ApprovalReviewer")
  memberships            Membership[]
  auditEvents            AuditEvent[]      @relation("AuditActor")
  uploadedRecordVersions RecordVersion[]   @relation("UploadedRecordVersion")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces  Workspace[]
  memberships Membership[]
  files       File[]
  records     Record[]
  auditEvents AuditEvent[]
}

model Workspace {
  id             String   @id @default(cuid())
  name           String
  slug           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships  Membership[]
  files        File[]
  records      Record[]
  auditEvents  AuditEvent[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Record {
  id                  String       @id @default(cuid())
  title               String
  description         String?
  status              RecordStatus @default(DRAFT)
  reviewerId          String?
  reviewNotes         String?
  submittedForReviewAt DateTime?
  approvedAt          DateTime?
  archivedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  userId              String
  organizationId      String?
  workspaceId         String?

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer         User?            @relation("CurrentReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  organization     Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  workspace        Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  versions         RecordVersion[]
  approvalRequests ApprovalRequest[]

  @@index([userId])
  @@index([reviewerId])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

model ApprovalRequest {
  id                String                @id @default(cuid())
  recordId          String
  requestedByUserId String
  reviewerId        String
  status            ApprovalRequestStatus @default(PENDING)
  requestNotes      String?
  decisionNotes     String?
  submittedAt       DateTime              @default(now())
  decidedAt         DateTime?

  record      Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
  requestedBy User   @relation("RequestedApproval", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewer    User   @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@index([reviewerId, status])
  @@index([requestedByUserId])
  @@index([submittedAt])
}

model RecordVersion {
  id               String   @id @default(cuid())
  recordId         String
  versionNumber    Int
  cid              String
  originalFilename String
  fileSize         Int
  mimeType         String?
  uploadedByUserId String
  uploadedAt       DateTime @default(now())

  record         Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
  uploadedByUser User   @relation("UploadedRecordVersion", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@unique([recordId, versionNumber])
  @@index([cid])
  @@index([recordId])
  @@index([uploadedByUserId])
  @@index([uploadedAt])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  workspaceId    String
  role           Role
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  auditEvents  AuditEvent[]

  @@unique([userId, workspaceId])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([userId, isDefault])
}

model AuditEvent {
  id             String   @id @default(cuid())
  action         String
  actorId        String?
  actorEmail     String?
  actorName      String?
  membershipId   String?
  organizationId String?
  workspaceId    String?
  targetType     String
  targetId       String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  actor        User?         @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  membership   Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([membershipId])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model File {
  id         String   @id @default(cuid())
  filename   String
  cid        String
  fileSize   Int
  mimeType   String?
  uploadedAt DateTime @default(now())

  userId         String
  organizationId String?
  workspaceId    String?
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  workspace      Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([cid])
  @@index([userId])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([uploadedAt])
  @@unique([userId, cid])
}
